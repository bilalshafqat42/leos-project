# Copy this file to .env.local and fill in real values.
# Used by src/app/api/contact/route.js to email Contact form submissions.

# Secret API key from your Resend account (https://resend.com/api-keys)
RESEND_API_KEY=

# Inbox that should receive site visit enquiries
CONTACT_TO_EMAIL=info@leosproject.ae

# "From" address — must be on a domain verified in Resend
CONTACT_FROM_EMAIL=enquiries@leosproject.ae
